---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Enquiry Received"
  description="Thank you for your coaching enquiry, we'll be in touch shortly."
>

  <section class="pt-32 pb-16 px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-white/[0.03] to-transparent"></div>
    <div class="max-w-5xl mx-auto relative">
      <p class="font-heading font-semibold text-lime text-sm uppercase tracking-widest mb-4">MO Goalkeeping</p>
      <h1 class="font-heading font-extrabold text-5xl lg:text-6xl xl:text-7xl text-white leading-tight mb-0 page-title">
        Enquiry <span class="text-lime">Received</span>
      </h1>
    </div>
  </section>

  <section class="py-8 px-6 pb-24">
    <div class="max-w-5xl mx-auto max-w-2xl">
      <p class="text-white text-lg leading-relaxed mb-8">
        Thanks for getting in touch, we'll review your enquiry and get back to you as soon as possible.
      </p>
      <a
        href="/"
        class="inline-flex items-center px-8 py-4 bg-lime text-dark font-heading font-bold uppercase tracking-wider text-sm rounded hover:bg-lime-dark transition-colors"
      >
        Back to Home
      </a>
    </div>
  </section>

</Layout>
