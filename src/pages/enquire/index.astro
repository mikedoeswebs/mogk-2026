---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Coaching Enquiry"
  description="Enquire about goalkeeper coaching with MO Goalkeeping — group sessions, Club MO/GK, and more on the Essex/Suffolk border."
>

  <!-- Page Header -->
  <section class="pt-32 pb-16 px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-white/[0.03] to-transparent"></div>
    <div class="max-w-5xl mx-auto relative">
      <p class="font-heading font-semibold text-lime text-sm uppercase tracking-widest mb-4">MO Goalkeeping</p>
      <h1 class="font-heading font-extrabold text-5xl lg:text-6xl xl:text-7xl text-white leading-tight mb-0 page-title">
        Coaching <span class="text-lime">Enquiry</span>
      </h1>
    </div>
  </section>

  <!-- Form section -->
  <section class="py-8 px-6 pb-24">
    <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-12">

      <div class="md:col-span-2">
        <p class="text-white text-lg leading-relaxed mb-8">
          Thank you for your interest in goalkeeper coaching services. Please fill in the form below and I'll get back to you as soon as possible.
        </p>

        <form
          id="enquiry-form"
          action="https://formspree.io/f/xgoboolz"
          method="POST"
          class="space-y-6"
        >
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block font-heading font-semibold text-white text-sm uppercase tracking-wider mb-2">
                Your name <span class="text-lime">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-white/5 border border-white/15 rounded-lg px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-lime focus:bg-white/8 transition-colors"
                placeholder="First and last name"
              />
            </div>
            <div>
              <label for="email" class="block font-heading font-semibold text-white text-sm uppercase tracking-wider mb-2">
                Your email <span class="text-lime">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-white/5 border border-white/15 rounded-lg px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-lime focus:bg-white/8 transition-colors"
                placeholder="your@email.com"
              />
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="phone" class="block font-heading font-semibold text-white text-sm uppercase tracking-wider mb-2">
                Phone number <span class="text-lime">*</span>
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                class="w-full bg-white/5 border border-white/15 rounded-lg px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-lime focus:bg-white/8 transition-colors"
                placeholder="07700 000000"
              />
            </div>
            <div>
              <label for="session-type" class="block font-heading font-semibold text-white text-sm uppercase tracking-wider mb-2">
                Session type <span class="text-lime">*</span>
              </label>
              <select
                id="session-type"
                name="session_type"
                required
                class="w-full bg-white/5 border border-white/15 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-lime focus:bg-white/8 transition-colors appearance-none"
              >
                <option value="" class="bg-dark text-white/50" disabled selected>Select type</option>
                <option value="Youth" class="bg-dark">Youth</option>
                <option value="Senior (16+)" class="bg-dark">Senior (16+)</option>
                <option value="Other" class="bg-dark">Other</option>
              </select>
            </div>
          </div>

          <div>
            <label for="location" class="block font-heading font-semibold text-white text-sm uppercase tracking-wider mb-2">
              Your location <span class="text-lime">*</span>
            </label>
            <input
              type="text"
              id="location"
              name="location"
              required
              class="w-full bg-white/5 border border-white/15 rounded-lg px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-lime focus:bg-white/8 transition-colors"
              placeholder="Town / village"
            />
          </div>

          <div>
            <label for="enquiry" class="block font-heading font-semibold text-white text-sm uppercase tracking-wider mb-2">
              Your enquiry <span class="text-lime">*</span>
            </label>
            <textarea
              id="enquiry"
              name="enquiry"
              required
              rows="5"
              class="w-full bg-white/5 border border-white/15 rounded-lg px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-lime focus:bg-white/8 transition-colors resize-y"
              placeholder="Please include information such as player age, experience, and what you are looking for."
            ></textarea>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="inline-flex items-center px-8 py-4 bg-lime text-dark font-heading font-bold uppercase tracking-wider text-sm rounded hover:bg-lime-dark transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Send Enquiry
          </button>
          <p id="form-error" class="hidden text-red-400 text-sm">Something went wrong — please try again or email us directly.</p>
        </form>
      </div>

      <aside class="space-y-6 lg:space-y-8">
        <div class="p-8 bg-white/5">
          <h3 class="font-heading font-bold text-white text-lg uppercase tracking-wider mb-4">Having trouble?</h3>
          <p class="text-white/60 leading-relaxed mb-3">
            If you have any issues submitting the form, please email me directly:
          </p>
          <a href="mailto:mike@mogoalkeeping.co.uk" class="text-lime hover:underline break-all">
            mike@mogoalkeeping.co.uk
          </a>
        </div>
        <div class="p-8 bg-white/5">
          <h3 class="font-heading font-bold text-white text-lg uppercase tracking-wider mb-4">Areas covered</h3>
          <p class="text-white/60 leading-relaxed">
            Halstead, Colchester, Braintree, Sudbury, Bury St Edmunds, and surrounding areas within approximately 12 miles of Halstead.
          </p>
        </div>
      </aside>

    </div>
  </section>

<script>
  const form = document.getElementById('enquiry-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const error = document.getElementById('form-error') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Sending…';
    error.classList.add('hidden');

    const res = await fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { Accept: 'application/json' },
    });

    if (res.ok) {
      (window as any).dataLayer = (window as any).dataLayer || [];
      (window as any).dataLayer.push({ event: 'generate_lead' });
      window.location.href = '/enquire/thank-you';
    } else {
      error.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Send Enquiry';
    }
  });
</script>

</Layout>
