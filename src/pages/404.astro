---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found"
  description="The page you're looking for doesn't exist. Head back to MO Goalkeeping."
>
  <section class="min-h-screen flex items-center justify-center px-6 text-center">
    <div class="max-w-xl">
      <p class="font-heading font-extrabold text-lime text-8xl md:text-9xl leading-none mb-4">404</p>
      <h1 class="font-heading font-extrabold text-3xl md:text-4xl text-white uppercase mb-4">Page Not Found</h1>
      <p class="text-white/55 text-lg mb-10">
        Looks like this one went over the bar. The page you're looking for doesn't exist or has moved.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/" class="inline-flex items-center px-6 py-3 bg-lime text-dark font-heading font-bold uppercase tracking-wider text-sm rounded hover:bg-lime-dark transition-colors">
          Back to Home
        </a>
        <a href="/goalkeeper-coaching/" class="inline-flex items-center px-6 py-3 border border-white/20 text-white font-heading font-bold uppercase tracking-wider text-sm rounded hover:border-lime hover:text-lime transition-colors">
          Goalkeeper Coaching
        </a>
      </div>
    </div>
  </section>
</Layout>
