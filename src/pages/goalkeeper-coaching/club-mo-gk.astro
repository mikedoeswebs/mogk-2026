---
import Layout from '../../layouts/Layout.astro';

const gallery = Array.from({ length: 12 }, (_, i) => ({
  src: `/images/club-mogk/club-mogk-${i + 1}.jpg`,
  alt: `Club MO/GK goalkeeper coaching session in Halstead`,
}));

// Replace with the correct YouTube video ID
const youtubeId = 'kcuy422k4dU';
---

<Layout
  title="Club MO/GK — Group Goalkeeper Coaching in Halstead"
  description="Club MO/GK is a group goalkeeper coaching programme for ages 6–16, running Monday evenings in Halstead, Essex. Fun, progressive sessions with FA-qualified coaches."
>

  <!-- Page Header -->
  <section class="pt-32 pb-16 px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-white/[0.03] to-transparent"></div>
    <div class="max-w-5xl mx-auto relative">
      <p class="font-heading font-semibold text-lime text-sm uppercase tracking-widest mb-4">Goalkeeper Coaching</p>
      <h1 class="font-heading font-extrabold text-5xl lg:text-6xl xl:text-7xl text-white leading-none tracking-tight mb-6 page-title">
        Club <span class="text-lime">MO/GK</span>
      </h1>
      <p class="text-white/60 text-xl max-w-2xl">
        Nurturing the next generation of goalkeepers through fun, inclusive group training sessions for all.
      </p>
    </div>
  </section>

  <!-- Hero group photo -->
  <section class="h-64 md:h-[500px] overflow-hidden">
    <img src="/images/club-mogk/club-mogk-full-crop.jpg" alt="Club MO/GK group photo — goalkeeper coaching in Halstead, Essex" class="w-full h-full object-cover object-top" />
  </section>

  <!-- Intro -->
  <section class="py-12 xl:py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-start">
        <div class="space-y-6 text-white/75 text-lg leading-relaxed">
          <h2 class="font-heading font-extrabold text-white text-3xl md:text-4xl">Group goalkeeper training for children aged 6-16</h2>
          <p>
            Club MO/GK offers group goalkeeper training sessions for children and young people in a safe, welcoming environment. Sessions run on Monday evenings at Halstead Leisure Centre in Essex, led by FA-qualified and DBS-checked coaches with decades of combined goalkeeping experience.
          </p>
          <p>
            Whether your young goalkeeper is just starting out or looking to push further, there's a place for them at Club MO/GK.
          </p>
        </div>
        <div class="space-y-4">
          <div class="border border-lime/30 p-6">
            <h3 class="font-heading font-bold text-lime text-lg uppercase tracking-wider mb-3">Session Details</h3>
            <dl class="text-base text-white space-y-2">
              <div class="flex gap-3"><dt class="text-white/40 w-20 shrink-0">When</dt><dd>Monday evenings</dd></div>
              <div class="flex gap-3"><dt class="text-white/40 w-20 shrink-0">Where</dt><dd>Halstead Leisure Centre, Essex</dd></div>
              <div class="flex gap-3"><dt class="text-white/40 w-20 shrink-0">Ages</dt><dd>6–16</dd></div>
              <div class="flex gap-3"><dt class="text-white/40 w-20 shrink-0">Coaches</dt><dd>FA qualified &amp; DBS checked</dd></div>
            </dl>
          </div>
          <a href="/enquire/" class="block text-center px-6 py-3 bg-lime text-dark font-heading font-bold uppercase tracking-wider text-sm rounded hover:bg-lime-dark transition-colors">
            Sign Up Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Two tracks -->
  <section class="py-12 xl:py-20 px-6 bg-white/[0.02]">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="font-heading font-extrabold text-4xl text-white mb-4">Two <span class="text-lime">Pathways</span></h2>
        <p class="text-white/60 text-lg max-w-xl mx-auto">We cater for all levels, from complete beginners to goalkeepers serious about developing their game.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="p-8 bg-white/5 hover:bg-white/10 transition-colors">
          <h3 class="font-heading font-extrabold text-white text-2xl mb-4">Club MO/GK <span class="text-lime">Fundamentals</span></h3>
          <p class="text-white/65 leading-relaxed">
            Our fundamentals sessions focus on fun and inclusivity. Goalkeepers of all levels are welcome. Players learn core skills while experiencing the physical, emotional, and social benefits of regular goalkeeper training in a positive group environment.
          </p>
        </div>
        <div class="p-8 bg-white/5 hover:bg-white/10 transition-colors">
          <h3 class="font-heading font-extrabold text-white text-2xl mb-4">Club MO/GK <span class="text-lime">Academy</span></h3>
          <p class="text-white/65 leading-relaxed">
            Our academy programme is aimed at players who are more serious about their goalkeeping. The sessions are tougher and more focused on development. The expectations are higher, but so are the rewards.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- YouTube video -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-heading font-extrabold text-4xl text-white mb-4 lg:mb-8 text-center">What to <span class="text-lime">expect</span></h2>
      <div class="relative w-full" style="padding-bottom: 56.25%;">
        <iframe
          class="absolute inset-0 w-full h-full"
          src={`https://www.youtube.com/embed/${youtubeId}`}
          title="Club MO/GK goalkeeper coaching"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Photo gallery -->
  <section class="py-4 px-6 pb-16">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2 md:gap-3">
        {gallery.map((img) => (
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 xl:py-20 px-6 text-center bg-white/[0.02]">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-heading font-extrabold text-4xl text-white mb-4">Come and <span class="text-lime">join us</span></h2>
      <p class="text-white/60 text-lg mb-8">Get in touch to find out more about Club MO/GK and how to sign up.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/enquire/" class="inline-flex items-center px-8 py-4 bg-lime text-dark font-heading font-bold uppercase tracking-wider text-sm rounded hover:bg-lime-dark transition-colors">
          Sign Up Now
        </a>
        <a href="/goalkeeper-coaching/" class="inline-flex items-center px-8 py-4 border border-white/20 text-white font-heading font-bold uppercase tracking-wider text-sm rounded hover:border-white/40 transition-colors">
          All Coaching Services
        </a>
      </div>
    </div>
  </section>

</Layout>
