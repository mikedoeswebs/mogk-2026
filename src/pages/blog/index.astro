---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Blog"
  description="Goalkeeper coaching thoughts, session ideas, and coaching insights from Mike at MO Goalkeeping."
>

  <!-- Page Header -->
  <section class="pt-32 pb-16 px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-white/[0.03] to-transparent"></div>
    <div class="max-w-5xl mx-auto relative">
      <p class="font-heading font-semibold text-lime text-sm uppercase tracking-widest mb-4">MO Goalkeeping</p>
      <h1 class="font-heading font-extrabold text-5xl lg:text-6xl xl:text-7xl text-white leading-tight mb-6 page-title">
        My <span class="text-lime">Thoughts</span>
      </h1>
      <p class="text-white/60 text-xl max-w-xl">
        Coaching insights, session ideas, and reflections on goalkeeping.
      </p>
    </div>
  </section>

  <!-- Posts grid -->
  <section class="py-8 px-6 pb-24">
    <div class="max-w-5xl mx-auto">
      {posts.length === 0 ? (
        <p class="text-white/50 text-center py-16">No posts yet — check back soon.</p>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {posts.map((post) => (
            <a href={`/blog/${post.id.replace(/\.md$/, '')}/`} class="bg-white/5 p-8 hover:border-lime/30 transition-colors group flex flex-col">
              <div class="flex items-center justify-between mb-6">
                <p class="text-white/40 font-heading text-xs uppercase tracking-wider">
                  {post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
                </p>
                {post.data.category && (
                  <span class="text-xs font-heading text-lime uppercase">{post.data.category}</span>
                )}
              </div>
              <h2 class="font-heading font-bold text-white text-lg mb-3 group-hover:text-lime transition-colors leading-snug">
                {post.data.title}
              </h2>
              <p class="text-white/50 text-sm leading-relaxed line-clamp-3 mb-4">{post.data.excerpt}</p>
              <span class="mt-auto inline-block text-lime font-heading font-semibold text-sm uppercase tracking-wider">Read more <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="inline-block align-middle ml-0.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

</Layout>
