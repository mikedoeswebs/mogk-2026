---
const navItems = [
  { label: 'Home', href: '/' },
  {
    label: 'Goalkeeper Coaching',
    href: '/goalkeeper-coaching/',
    children: [
      { label: 'Club MO/GK', href: '/goalkeeper-coaching/club-mo-gk/' },
    ],
  },
  { label: 'Resources', href: '/resources/' },
  { label: 'About', href: '/about/' },
  { label: 'Blog', href: '/blog/' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="fixed top-0 left-0 right-0 z-50 h-16 md:h-20 bg-dark/90 backdrop-blur-sm border-b border-white/5">
  <div class="max-w-7xl mx-auto px-6 h-full flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="font-heading text-xl md:text-2xl text-white uppercase tracking-widest" aria-label="MO Goalkeeping home">
      <span class="text-white font-extrabold">MO</span><span class="text-lime font-bold">/</span><span class="font-light">GK</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden xl:flex self-stretch gap-1" aria-label="Main navigation">
      {navItems.map((item) => (
        <div class="relative group h-full flex">
          <a
            href={item.href}
            class:list={[
              'p-4 font-heading font-semibold text-sm uppercase tracking-wider transition-colors rounded items-center flex',
              isActive(item.href)
                ? 'text-lime'
                : 'text-white hover:text-lime',
            ]}
          >
            {item.label}
            {item.children && (
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="ml-0.5 opacity-50 inline-block align-middle"><polyline points="6 9 12 15 18 9"/></svg>
            )}
          </a>
          {item.children && (
            <div class="absolute top-full left-0 min-w-full bg-dark opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class:list={[
                    'block p-4 font-heading font-semibold text-sm uppercase tracking-wider transition-colors whitespace-nowrap',
                    isActive(child.href)
                      ? 'text-lime'
                      : 'text-white hover:text-lime hover:bg-white/5',
                  ]}
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </nav>

    <!-- Enquire CTA (desktop) + Mobile hamburger -->
    <div class="flex items-center gap-4">
      <a href="/enquire/" class="hidden xl:inline-flex items-center px-5 py-2.5 bg-lime text-dark font-heading font-bold text-sm uppercase tracking-wider rounded hover:bg-lime-dark transition-colors">
        Enquire
      </a>

      <!-- Hamburger -->
      <button id="nav-toggle" class="xl:hidden p-2 text-white hover:text-lime" aria-label="Open navigation" aria-expanded="false" aria-controls="mobile-nav">
        <svg id="icon-open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg id="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Nav -->
<div id="mobile-nav" class="fixed inset-0 z-40 bg-dark translate-x-full transition-transform duration-300 xl:hidden" aria-label="Mobile navigation">
  <div class="pt-24 px-6 pb-12 overflow-y-auto h-full">
    <nav class="flex flex-col gap-1">
      {navItems.map((item) => (
        <div>
          <a
            href={item.href}
            class:list={[
              'block py-3 font-heading font-bold text-lg uppercase tracking-wider border-b border-white/10',
              isActive(item.href) ? 'text-lime' : 'text-white/80',
            ]}
          >
            {item.label}
          </a>
          {item.children && (
            <div class="pl-4">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class:list={[
                    'block py-2.5 font-heading font-semibold text-base uppercase tracking-wider border-b border-white/5',
                    isActive(child.href) ? 'text-lime' : 'text-white/60',
                  ]}
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
      <a href="/enquire/" class="mt-6 inline-flex justify-center items-center px-5 py-3 bg-lime text-dark font-heading font-bold text-sm uppercase tracking-wider rounded hover:bg-lime-dark transition-colors">
        Enquire Now
      </a>
    </nav>
    <div class="mt-10 flex gap-5">
      <a href="https://twitter.com/MOGoalkeeping" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-lime transition-colors" aria-label="Twitter">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href="https://instagram.com/mogoalkeeping_" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-lime transition-colors" aria-label="Instagram">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
      </a>
      <a href="https://www.youtube.com/channel/UCmvFNdZXIGklqmHoVcpLAhg" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-lime transition-colors" aria-label="YouTube">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      </a>
      <a href="https://www.facebook.com/mogoalkeeping/" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-lime transition-colors" aria-label="Facebook">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
    </div>
  </div>
</div>

<script>
  const toggle = document.getElementById('nav-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.contains('translate-x-0');
    if (isOpen) {
      mobileNav?.classList.remove('translate-x-0');
      mobileNav?.classList.add('translate-x-full');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    } else {
      mobileNav?.classList.remove('translate-x-full');
      mobileNav?.classList.add('translate-x-0');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
    }
  });
</script>
