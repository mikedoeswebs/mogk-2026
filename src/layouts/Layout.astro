---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Goalkeeper coaching in Halstead, Colchester, Braintree, Sudbury, Bury St Edmunds and the Suffolk/Essex border.',
  ogImage = '/images/banners/clubmogk-banner-1.jpg',
} = Astro.props;
const fullTitle = title === 'Home' ? 'MO Goalkeeping | Goalkeeper Coaching in Essex & Suffolk' : `${title} | MO Goalkeeping`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ccff00" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="MO Goalkeeping" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@MOGoalkeeping" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/images/icons/apple-touch-icon.png" />
    <link rel="apple-touch-icon" sizes="152x152" href="/images/icons/apple-touch-icon-152x152.png" />
    <link rel="apple-touch-icon" sizes="167x167" href="/images/icons/apple-touch-icon-167x167.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/icons/apple-touch-icon-180x180.png" />
    <link rel="icon" sizes="192x192" href="/images/icons/icon-hires.png" />
    <link rel="icon" sizes="128x128" href="/images/icons/icon-normal.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;600;700;800&family=Noto+Sans:ital,wght@0,400;0,600;1,400&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;600;700;800&family=Noto+Sans:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" /></noscript>
    <title>{fullTitle}</title>
    <!-- LocalBusiness structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "MO Goalkeeping",
      "url": "https://mogoalkeeping.co.uk",
      "logo": "https://mogoalkeeping.co.uk/images/icons/apple-touch-icon-180x180.png",
      "description": "Specialist goalkeeper coaching in Halstead, Colchester, Braintree, Sudbury, Bury St Edmunds and across the Suffolk/Essex border.",
      "areaServed": ["Halstead", "Colchester", "Braintree", "Sudbury", "Bury St Edmunds", "Suffolk", "Essex"],
      "address": {
        "@type": "PostalAddress",
        "addressRegion": "Essex/Suffolk",
        "addressCountry": "GB"
      },
      "sameAs": [
        "https://twitter.com/MOGoalkeeping",
        "https://www.instagram.com/mogoalkeeping_",
        "https://www.facebook.com/mogoalkeeping/",
        "https://www.youtube.com/channel/UCmvFNdZXIGklqmHoVcpLAhg"
      ]
    })} />
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-MCCRRCF');</script>
    <!-- End Google Tag Manager -->
  </head>
  <body class="bg-dark text-white font-body antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MCCRRCF" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
